{
  "name": "ROS2 Jazzy",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "remoteUser": "ubuntu",

  "runArgs": [
    "--network=host",
    "--ipc=host"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ranch-hand-robotics.rde-ros-2"
      ]
    }
  },

  "postCreateCommand": "rosdep update || true"
}